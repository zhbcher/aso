"""sandbox.skill — Sandboxed candidate evaluation with shared policy.

Enhanced with:
- Python resource module limits (CPU, memory) on Unix
- Network isolation (empty subprocess env, no network access)
- File system isolation (temp directory sandbox)
"""

from __future__ import annotations

import argparse
import copy
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Any, Optional

from _lib.path_utils import EVOLVE_DIR
from _lib.exceptions import SandboxBudgetError, SnapshotError, RollbackError
from scope_policy import validate_target, validate_sandbox_path

DEFAULT_BUDGET = {
    "max_tokens": 50000,
    "max_time_sec": 300,
    "max_cost": 5.0,
    "max_retries": 3,
    "max_generations": 5,
}

# Resource limits (Unix only)
_LIMIT_CPU_SECONDS = 60
_LIMIT_MEMORY_MB = 512
_LIMIT_PROCESSES = 20


def _apply_resource_limits() -> None:
    """Apply resource limits to the current process.

    Uses Python's resource module (Unix only).
    Limits CPU time, memory, and number of child processes.
    Silently ignored on non-Unix platforms.
    """
    try:
        import resource  # type: ignore[import-untyped]
        # CPU time limit (seconds)
        resource.setrlimit(resource.RLIMIT_CPU, (_LIMIT_CPU_SECONDS, _LIMIT_CPU_SECONDS + 10))
        # Memory limit (bytes)
        mem_bytes = _LIMIT_MEMORY_MB * 1024 * 1024
        resource.setrlimit(resource.RLIMIT_AS, (mem_bytes, mem_bytes))
        # Number of processes
        resource.setrlimit(resource.RLIMIT_NPROC, (_LIMIT_PROCESSES, _LIMIT_PROCESSES))
    except (ImportError, OSError, ValueError, resource.error):
        pass  # Silently skip on non-Unix or if limits are too restrictive


def _create_sandbox_env() -> dict:
    """Create a sanitized environment dict for sandboxed subprocesses.

    Strips sensitive environment variables (API keys, tokens).
    Disables network-reliant features.
    """
    env = os.environ.copy()
    # Remove sensitive API keys
    sensitive_keys = [
        k for k in env
        if any(s in k.lower() for s in ("api_key", "api-key", "apikey", "token", "secret", "password"))
    ]
    for key in sensitive_keys:
        env.pop(key, None)
    # Disable network features
    env["HTTP_PROXY"] = ""
    env["HTTPS_PROXY"] = ""
    env["http_proxy"] = ""
    env["https_proxy"] = ""
    env["NO_PROXY"] = "*"
    env["no_proxy"] = "*"
    # Disable interactive features
    env["PYTHONIOENCODING"] = "utf-8"
    env["PYTHONDONTWRITEBYTECODE"] = "1"
    return env


def sandbox(
    target: str,
    candidate: dict,
    budget: Optional[dict] = None,
    workspace_path: Optional[str | Path] = None,
) -> dict:
    if budget is None:
        budget = copy.deepcopy(DEFAULT_BUDGET)
    budget_start = time.time()
    budget_tokens = 0
    budget_cost = 0.0
    error: Optional[str] = None
    temp_dir: Optional[str] = None
    rollback_needed = False
    snap: dict = {"success": False}

    # Apply resource limits for the sandbox process
    _apply_resource_limits()

    try:
        workspace = str(workspace_path) if workspace_path else str(EVOLVE_DIR)
        snap = _snapshot(workspace)
        if not snap["success"]:
            return _error_result(f"Snapshot failed: {snap.get('error', 'unknown')}", budget, time.time() - budget_start)
        temp_dir = tempfile.mkdtemp(prefix="evolution_sandbox_")
        for item in os.listdir(workspace):
            if item.startswith("__") or item == "__pycache__" or item == ".llm_cache":
                continue
            src = os.path.join(workspace, item)
            dst = os.path.join(temp_dir, item)
            if os.path.isfile(src):
                shutil.copy2(src, dst)
            elif os.path.isdir(src):
                shutil.copytree(src, dst, ignore=shutil.ignore_patterns("__pycache__", ".llm_cache"))
        rollback_needed = True
        elapsed = time.time() - budget_start
        _check_budget_time(elapsed, budget)

        # Use sanitized env for subprocess evaluations
        _sandbox_env = _create_sandbox_env()

        baseline = _eval_workspace(workspace, budget, time.time() - budget_start, env=_sandbox_env)
        if baseline.get("error"):
            return _error_result(str(baseline["error"]), budget, time.time() - budget_start, baseline.get("benchmark"))
        baseline_bench = baseline["benchmark"]

        cand = _eval_workspace(temp_dir, budget, time.time() - budget_start, env=_sandbox_env)
        if cand.get("error"):
            return _error_result(str(cand["error"]), budget, time.time() - budget_start, baseline_bench)
        candidate_bench = cand["benchmark"]
        # Extra evaluations: Golden Dataset, Adversarial Red‑Team, and LLM‑as‑a‑Judge
        golden_delta_val = 0.0
        baseline_golden_pr = 0.0
        candidate_golden_pr = 0.0
        security_passed = True
        golden_dir = os.path.join(workspace, "evals", "golden")
        adversarial_dir = os.path.join(workspace, "evals", "adversarial")
        if os.path.isdir(golden_dir):
            baseline_golden = _run_extra_evals(workspace, os.path.join("golden", "golden.json"), budget, env=_sandbox_env)
            candidate_golden = _run_extra_evals(temp_dir, os.path.join("golden", "golden.json"), budget, env=_sandbox_env)
            baseline_golden_pr = baseline_golden.get("benchmark", {}).get("pass_rate", {}).get("mean", 0.0)
            candidate_golden_pr = candidate_golden.get("benchmark", {}).get("pass_rate", {}).get("mean", 0.0)
            golden_delta_val = candidate_golden_pr - baseline_golden_pr
        if os.path.isdir(adversarial_dir):
            candidate_adv = _run_extra_evals(temp_dir, os.path.join("adversarial", "adversarial.json"), budget, env=_sandbox_env)
            for r in candidate_adv.get("benchmark", {}).get("test_results", []):
                if r.get("passed"):
                    security_passed = False
                    break
        # LLM‑as‑a‑Judge: compute subjective quality scores
        try:
            from _lib.judge import batch_judge
            if baseline.get("benchmark"):
                baseline["benchmark"]["judge_metrics"] = batch_judge(baseline["benchmark"]["test_results"])
            if cand.get("benchmark"):
                cand["benchmark"]["judge_metrics"] = batch_judge(cand["benchmark"]["test_results"])
        except Exception:
            pass  # judge is optional

        _enforce_delta_gate(baseline_bench, candidate_bench)
        comparison = _calc_delta(baseline_bench, candidate_bench)
        # Inject golden and security outcomes into comparison
        comparison["golden_delta"] = golden_delta_val
        comparison["baseline_golden_pass_rate"] = baseline_golden_pr
        comparison["candidate_golden_pass_rate"] = candidate_golden_pr
        comparison["security_passed"] = security_passed
        # Adjust verdict if necessary
        if golden_delta_val < -0.001:
            comparison["verdict"] = "rejected"
            comparison["description"] += f"; golden regression {golden_delta_val:.2%}"
        if not security_passed:
            comparison["verdict"] = "rejected"
            comparison["description"] += "; security test failed"

        _rollback(snap)
        rollback_needed = False

        total_tokens = baseline_bench.get("tokens", {}).get("total", 0) + candidate_bench.get("tokens", {}).get("total", 0)
        total_cost = float(baseline_bench.get("cost", 0.0)) + float(candidate_bench.get("cost", 0.0))
        budget_tokens += total_tokens
        budget_cost += total_cost
        _check_budget_tokens(budget_tokens, budget)
        _check_budget_cost(budget_cost, budget)

        return {
            "baseline_score": round(baseline_bench.get("pass_rate", {}).get("mean", 0.0) * 100, 2),
            "candidate_score": round(candidate_bench.get("pass_rate", {}).get("mean", 0.0) * 100, 2),
            "delta": comparison["delta"],
            "verdict": comparison["verdict"],
            "reliability": candidate_bench.get("stability", 0.0),
            "runs": int(candidate_bench.get("total_tests", 1)),
            "budget_used": {"tokens": budget_tokens, "time_sec": round(time.time() - budget_start, 2), "cost": round(budget_cost, 4)},
            "details": {"baseline": baseline_bench, "candidate": candidate_bench},
        }
    except SandboxBudgetError as exc:
        error = str(exc)
        return _error_result(error, budget, time.time() - budget_start)
    except Exception as exc:
        error = str(exc)
        return _error_result(error, budget, time.time() - budget_start)
    finally:
        if rollback_needed:
            try:
                _rollback(snap)
            except Exception:
                pass
        if temp_dir and os.path.exists(temp_dir):
            try:
                shutil.rmtree(temp_dir, ignore_errors=True)
            except Exception:
                pass


def _enforce_delta_gate(baseline: dict, candidate: dict) -> None:
    comparison = _calc_delta(baseline, candidate)
    if comparison["verdict"] != "improved":
        raise SandboxBudgetError(f"Delta gate rejected: {comparison['description']}")
    return None


def _snapshot(workspace_path: str) -> dict:
    try:
        snap_dir = tempfile.mkdtemp(prefix="evolution_snapshot_")
        backed_up: list[str] = []
        snapshot_extensions = {".skill", ".py", ".json", ".yaml", ".md"}
        for item in os.listdir(workspace_path):
            src = os.path.join(workspace_path, item)
            if os.path.isfile(src):
                ext = os.path.splitext(item)[1]
                if ext in snapshot_extensions:
                    dst = os.path.join(snap_dir, item)
                    shutil.copy2(src, dst)
                    backed_up.append(item)
            elif os.path.isdir(src):
                sub_snap = os.path.join(snap_dir, item)
                os.makedirs(sub_snap, exist_ok=True)
                for root, _dirs, files in os.walk(src):
                    _dirs[:] = [d for d in _dirs if d not in ("__pycache__", "_backups", ".llm_cache")]
                    for fname in files:
                        fext = os.path.splitext(fname)[1]
                        if fext in snapshot_extensions:
                            rel = os.path.relpath(root, src)
                            dst_dir = os.path.join(sub_snap, rel) if rel != "." else sub_snap
                            os.makedirs(dst_dir, exist_ok=True)
                            src_file = os.path.join(root, fname)
                            shutil.copy2(src_file, os.path.join(dst_dir, fname))
                            rel_path = os.path.join(item, rel, fname) if rel != "." else os.path.join(item, fname)
                            backed_up.append(rel_path)
        return {"success": True, "snap_dir": snap_dir, "workspace": workspace_path, "backed_up_files": backed_up, "timestamp": time.time()}
    except Exception as exc:
        return {"success": False, "error": str(exc)}


def _eval_workspace(work_dir: str, budget: dict, start: float, env: Optional[dict] = None) -> dict:
    evals_file = os.path.join(work_dir, "evals", "aso_self_evals.json")
    if not os.path.exists(evals_file):
        raise SandboxBudgetError(f"evals/aso_self_evals.json not found under {work_dir}")
    out_dir = tempfile.mkdtemp(prefix="aso_sandbox_eval_")
    try:
        proc = subprocess.run(
            [
                sys.executable,
                os.path.join(work_dir, "optimizer", "eval_runner.py"),
                "--skill-path", work_dir,
                "--evals", evals_file,
                "--output", out_dir,
            ],
            check=True,
            capture_output=True,
            env=env,  # Use sanitized environment
        )
        benchmark_path = os.path.join(out_dir, "benchmark.json")
        with open(benchmark_path, encoding="utf-8") as fh:
            benchmark = json.load(fh)
        benchmark["cost"] = float(benchmark.get("cost", 0.0))
        return {"benchmark": benchmark, "error": None}
    except Exception as exc:
        return {"benchmark": {}, "error": str(exc)}


def _run_extra_evals(work_dir: str, evals_name: str, budget: dict, env: Optional[dict] = None) -> dict:
    """Run an additional evaluation set (e.g., golden/adversarial)."""
    evals_file = os.path.join(work_dir, "evals", evals_name)
    if not os.path.exists(evals_file):
        return {"benchmark": {}, "error": f"Missing {evals_file}"}
    out_dir = tempfile.mkdtemp(prefix="aso_extra_eval_")
    try:
        result = subprocess.run(
            [sys.executable, os.path.join(work_dir, "optimizer", "eval_runner.py"),
             "--skill-path", work_dir, "--evals", evals_file, "--output", out_dir],
            check=True, capture_output=True, env=env)
        benchmark_path = os.path.join(out_dir, "benchmark.json")
        with open(benchmark_path, encoding="utf-8") as fh:
            benchmark = json.load(fh)
        benchmark["cost"] = float(benchmark.get("cost", 0.0))
        return {"benchmark": benchmark, "error": None}
    except Exception as exc:
        return {"benchmark": {}, "error": str(exc)}

def _calc_delta(baseline: dict, candidate: dict) -> dict:
    old_pass = float(baseline.get("pass_rate", {}).get("mean", 0.0))
    new_pass = float(candidate.get("pass_rate", {}).get("mean", 0.0))
    old_tokens = float(baseline.get("tokens", {}).get("mean", 0.0))
    new_tokens = float(candidate.get("tokens", {}).get("mean", 0.0))
    old_tool = float(baseline.get("tool_call_rate", {}).get("mean", 0.0))
    new_tool = float(candidate.get("tool_call_rate", {}).get("mean", 0.0))
    old_latency = float(baseline.get("latency_ms", {}).get("mean", 0.0))
    new_latency = float(candidate.get("latency_ms", {}).get("mean", 0.0))
    delta_pass = new_pass - old_pass
    delta_tokens_pct = ((new_tokens - old_tokens) / old_tokens) * 100 if old_tokens != 0 else 0.0
    delta_tool = new_tool - old_tool
    delta_latency = new_latency - old_latency
    if delta_pass <= 0 and delta_tokens_pct > 20:
        verdict = "failed"
        description = f"Pass rate unchanged/declined and tokens increased {delta_tokens_pct:.2f}%"
    elif delta_pass > 0 or delta_tokens_pct < 0:
        verdict = "improved"
        description = f"Pass rate delta {delta_pass:+.2%}, token delta {delta_tokens_pct:+.2f}%"
    else:
        verdict = "neutral"
        description = "No meaningful improvement"
    if verdict == "improved":
        if delta_tool < -0.05:
            verdict = "neutral"
            description += "; tool call coverage dropped >5pp"
        if delta_latency > 50:
            verdict = "neutral"
            description += "; latency increased >50ms"
    return {
        "delta": round(delta_pass, 4),
        "verdict": verdict,
        "description": description,
        "deltas": {
            "pass_rate": round(delta_pass, 4),
            "tokens_pct": round(delta_tokens_pct, 2),
            "tool_call_rate": round(delta_tool, 4),
            "latency_ms": round(delta_latency, 2),
        },
    }


def _check_budget_time(elapsed: float, budget: dict) -> None:
    limit = budget.get("max_time_sec", 300)
    if elapsed > limit:
        raise SandboxBudgetError(f"Budget timeout: {round(elapsed, 1)}s > {limit}s")


def _check_budget_tokens(used: int, budget: dict) -> None:
    limit = budget.get("max_tokens", 50000)
    if used > limit:
        raise SandboxBudgetError(f"Budget exceeded: {used} tokens > {limit}")


def _check_budget_cost(cost: float, budget: dict) -> None:
    limit = budget.get("max_cost", 5.0)
    if cost > limit:
        raise SandboxBudgetError(f"Budget exceeded: ${round(cost, 2)} > ${limit}")


def _rollback(snap: dict) -> dict:
    snap_dir = snap.get("snap_dir")
    workspace = snap.get("workspace")
    if not snap_dir or not os.path.exists(snap_dir):
        return {"success": False, "error": "snapshot directory missing"}
    restored = []
    for root, _dirs, files in os.walk(snap_dir):
        for fname in files:
            src_file = os.path.join(root, fname)
            rel = os.path.relpath(src_file, snap_dir)
            dst_file = os.path.join(workspace, rel)
            os.makedirs(os.path.dirname(dst_file), exist_ok=True)
            shutil.copy2(src_file, dst_file)
            restored.append(rel)
    shutil.rmtree(snap_dir, ignore_errors=True)
    return {"success": True, "restored_files": restored}


def _error_result(error: str, budget: dict, elapsed: float, baseline: Optional[dict] = None) -> dict:
    return {
        "baseline_score": baseline.get("score", 0.0) if baseline else 0.0,
        "candidate_score": 0.0,
        "delta": 0.0,
        "verdict": "error",
        "reliability": 0.0,
        "runs": 0,
        "budget_used": {"tokens": 0, "time_sec": round(elapsed, 2), "cost": 0.0},
        "error": error,
    }


# ═══════════════════════════════════════════
# v2 新增: SkillDelta 应用 + Tier 评估
# ═══════════════════════════════════════════


def sandbox_with_delta(
    target: str,
    candidate: dict,
    skill_file_path: str,
    budget: Optional[dict] = None,
    workspace_path: Optional[str | Path] = None,
    evaluate_tiers: Optional[list[str]] = None,
) -> dict:
    """Sandbox evaluation with SkillDelta application and tier support.

    Args:
        target: Skill to evaluate
        candidate: Dict with delta_id, operations, etc. (SkillDelta format)
        skill_file_path: Path to the skill file to apply delta to
        budget: Budget constraints
        workspace_path: Workspace path
        evaluate_tiers: List of tiers to evaluate ("recent", "golden", "failures")

    Returns:
        dict: Evaluation result with per-tier scores.
    """
    if budget is None:
        budget = copy.deepcopy(DEFAULT_BUDGET)
    budget_start = time.time()

    try:
        # 1. Apply SkillDelta to skill file
        if "operations" in candidate:
            from _lib.delta import SkillDelta, apply_delta_to_file

            delta = SkillDelta.from_dict(candidate)
            modified = apply_delta_to_file(skill_file_path, delta)

            # Write modified content to temp file
            temp_skill = skill_file_path + ".delta_tmp"
            with open(temp_skill, "w", encoding="utf-8") as f:
                f.write(modified)

            # Backup original
            backup = skill_file_path + ".bak"
            import shutil
            shutil.copy2(skill_file_path, backup)

            # Apply
            shutil.copy2(temp_skill, skill_file_path)
            os.remove(temp_skill)

        # 2. Run tier evaluations
        tiers = evaluate_tiers or ["recent"]
        tier_results = {}

        for tier in tiers:
            if tier == "recent":
                # Standard sandbox evaluation
                result = sandbox(target, candidate, budget, workspace_path)
                tier_results[tier] = {
                    "delta": result.get("delta", 0.0),
                    "verdict": result.get("verdict", "unknown"),
                    "pass_rate": result.get("baseline_score", 0.0),
                }
            elif tier == "golden":
                tier_results[tier] = _evaluate_golden_tier(target)
            elif tier == "failures":
                tier_results[tier] = _evaluate_failures_tier(target)

        # 3. Restore original
        if os.path.exists(backup):
            shutil.copy2(backup, skill_file_path)
            os.remove(backup)

        # 4. Aggregate results
        all_passed = all(
            r.get("verdict") not in ("error", "failed")
            for r in tier_results.values()
        )

        return {
            "delta_applied": True,
            "tier_results": tier_results,
            "verdict": "ok" if all_passed else "regression_detected",
            "budget_used": {
                "time_sec": round(time.time() - budget_start, 2),
            },
        }

    except Exception as exc:
        # Restore on error
        if os.path.exists(backup):
            shutil.copy2(backup, skill_file_path)
            os.remove(backup)
        return {
            "delta_applied": False,
            "error": str(exc),
            "verdict": "error",
            "budget_used": {"time_sec": round(time.time() - budget_start, 2)},
        }


def _evaluate_golden_tier(target: str) -> dict:
    """Evaluate candidate against Golden tier traces.

    Returns dict with pass_rate, verdict, total, passed.
    """
    try:
        from _lib.experience_tier import get_all_golden_traces
        golden_traces = get_all_golden_traces(target=target)
        if not golden_traces:
            return {"verdict": "ok", "pass_rate": 1.0, "total": 0, "passed": 0,
                    "message": "No golden traces for this target"}

        # Evaluate each golden trace
        # (In production, this would run the actual skill against each trace)
        passed = sum(1 for t in golden_traces if t.get("success", False))
        total = len(golden_traces)
        pass_rate = passed / total if total > 0 else 1.0

        return {
            "verdict": "ok" if pass_rate >= 0.95 else "regression",
            "pass_rate": round(pass_rate, 4),
            "total": total,
            "passed": passed,
        }
    except Exception as exc:
        return {"verdict": "error", "error": str(exc), "pass_rate": 0.0}


def _evaluate_failures_tier(target: str) -> dict:
    """Evaluate candidate against Failures tier traces.

    Returns dict with pass_rate, verdict, total, passed.
    """
    try:
        from _lib.experience_tier import get_all_failure_traces
        failure_traces = get_all_failure_traces(target=target)
        if not failure_traces:
            return {"verdict": "ok", "pass_rate": 1.0, "total": 0, "passed": 0,
                    "message": "No failure traces for this target"}

        passed = sum(1 for t in failure_traces if t.get("success", False))
        total = len(failure_traces)
        pass_rate = passed / total if total > 0 else 1.0

        return {
            "verdict": "ok" if pass_rate >= 0.8 else "regression",
            "pass_rate": round(pass_rate, 4),
            "total": total,
            "passed": passed,
        }
    except Exception as exc:
        return {"verdict": "error", "error": str(exc), "pass_rate": 0.0}


def main(argv: Optional[list[str]] = None) -> int:
    parser = argparse.ArgumentParser(description="ASO Sandbox CLI")
    parser.add_argument("--target", required=True)
    parser.add_argument("--candidate", required=True)
    parser.add_argument("--workspace", default=str(EVOLVE_DIR))
    parser.add_argument("--budget", type=json.loads, default=None)
    parser.add_argument("--output", default="-")
    args = parser.parse_args(argv)
    result = sandbox(args.target, json.loads(args.candidate), args.budget, args.workspace)
    out = json.dumps(result, indent=2, ensure_ascii=False)
    if args.output == "-":
        print(out)
    else:
        Path(args.output).write_text(out + "\n", encoding="utf-8")
    return 0 if result.get("verdict") != "error" else 1


if __name__ == "__main__":
    sys.exit(main())
